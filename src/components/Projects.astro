---
// Projects section - featured projects and highlights
const projects = [
  {
    name: 'TutAll',
    descKey: 'tutall-desc',
    descDefault: 'SaaS platform for tutors — lesson management, AI-powered transcription, homework generation, payments. Architected and built end-to-end: Go backend on GCP (Cloud Run, Cloud SQL, Vertex AI), React frontend.',
    link: 'https://tutall.app',
    linkText: 'tutall.app ↗',
    featured: true,
  },
  {
    name: 'Release automation bot',
    descKey: 'release-bot-desc',
    descDefault: 'Slack bot that automates the entire release process — changelog generation, version tagging, production deploys, team notifications. Replaced a manual workflow that used to take 30+ minutes per release.',
  },
  {
    name: 'API Gateway',
    descKey: 'api-gateway-desc',
    descDefault: 'Built from scratch as a proxy layer for all external API calls. Identified caching opportunities that significantly reduced response times across dependent services.',
  },
  {
    name: 'Observability stack',
    descKey: 'observability-desc',
    descDefault: 'Set up the full monitoring stack from zero — distributed tracing, context-aware logging, metrics dashboards. Now the first thing the team reaches for during incidents.',
  },
  {
    name: 'Data pipeline optimization',
    descKey: 'data-pipeline-desc',
    descDefault: 'Identified bottlenecks through traces and metrics in a data processing pipeline. Redesigned for parallel execution — significant throughput improvement.',
  },
  {
    name: 'Claude Code workflow',
    descKey: 'claude-workflow-desc',
    descDefault: 'Custom Git automation built around Claude Code — pre-commit hooks, branch management, slash commands for PR creation and code review. Daily driver for AI-assisted development.',
  },
  {
    name: 'Messaging integrations',
    descKey: 'messaging-desc',
    descDefault: 'Built Instagram and Telegram messaging integrations for LiveChat — webhooks, media handling, OAuth, real-time message delivery. The unglamorous work that makes products talk to each other.',
  },
];
---

<section>
  <p class="section-label" data-i18n="projects-label">Projects & highlights</p>
  <div class="projects-list">
    {projects.map((project) => (
      <div class:list={['project-row', { featured: project.featured }]}>
        <div class="project-content">
          <div class="project-name">{project.name}</div>
          <div class="project-desc" data-i18n={project.descKey}>{project.descDefault}</div>
        </div>
        {project.link && (
          <a href={project.link} target="_blank" rel="noopener noreferrer" class="project-link">
            {project.linkText}
          </a>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .project-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    gap: 1.5rem;
  }

  .project-row:last-child {
    border-bottom: none;
  }

  .project-row.featured {
    background: rgba(74, 240, 160, 0.03);
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    margin-left: -1.25rem;
    padding-right: 1.25rem;
    margin-right: -1.25rem;
    margin-bottom: 0.5rem;
  }

  .project-content {
    flex: 1;
    min-width: 0;
  }

  .project-name {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--heading);
    margin-bottom: 0.35rem;
  }

  .project-row.featured .project-name {
    color: var(--accent);
  }

  .project-desc {
    font-size: 0.8rem;
    color: var(--subtle);
    line-height: 1.6;
  }

  .project-link {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.7;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .project-link:hover {
    opacity: 1;
  }

  @media (max-width: 560px) {
    .project-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .project-row.featured {
      margin-left: 0;
      margin-right: 0;
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .project-link {
      align-self: flex-start;
    }
  }
</style>
