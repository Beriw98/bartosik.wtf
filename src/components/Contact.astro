---
// Contact section with email and booking CTA
---

<section class="contact-block" id="contact">
  <h2 data-i18n="contact-h2">Let's talk.</h2>
  <p data-i18n="contact-sub">// part-time · remote · B2B</p>
  <a href="mailto:maciek@bartosik.wtf" class="contact-email">maciek@bartosik.wtf</a>
  <span class="contact-or" data-i18n="contact-or">or</span>
  <a href="https://calendar.app.google/abnJyttKrz5yXWHC6" target="_blank" rel="noopener noreferrer" class="btn-primary" data-i18n="contact-book">Book a call →</a>
</section>

<style>
  .contact-block {
    text-align: center;
    padding: 4rem 0 6rem;
  }

  .contact-block h2 {
    font-family: var(--serif);
    font-size: 2.2rem;
    color: var(--heading);
    font-weight: 400;
    margin-bottom: 0.75rem;
  }

  .contact-block p {
    color: var(--subtle);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    font-family: var(--mono);
  }

  .contact-email {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(74, 240, 160, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .contact-email:hover {
    border-color: var(--accent);
  }

  .contact-or {
    display: block;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    margin: 1.25rem 0;
  }
</style>
