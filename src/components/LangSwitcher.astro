---
// LangSwitcher - client-side interactive island for EN/PL toggle
---

<div class="lang-switcher" role="group" aria-label="Language selector">
  <button class="lang-btn" id="btn-en" aria-label="Switch to English">EN</button>
  <button class="lang-btn" id="btn-pl" aria-label="Przełącz na polski">PL</button>
</div>

<script>
  import en from '../i18n/en.json';
  import pl from '../i18n/pl.json';

  const translations: Record<string, Record<string, string>> = { en, pl };

  function setLang(lang: string) {
    document.documentElement.lang = lang;
    const dict = translations[lang];

    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key] !== undefined) {
        el.innerHTML = dict[key];
      }
    });

    document.getElementById('btn-en')?.classList.toggle('active', lang === 'en');
    document.getElementById('btn-pl')?.classList.toggle('active', lang === 'pl');
    localStorage.setItem('lang', lang);
  }

  // Attach click handlers
  document.getElementById('btn-en')?.addEventListener('click', () => setLang('en'));
  document.getElementById('btn-pl')?.addEventListener('click', () => setLang('pl'));

  // Auto-detect on load: saved pref → browser language → default EN
  const saved = localStorage.getItem('lang');
  if (saved && translations[saved]) {
    setLang(saved);
  } else {
    const browser = (navigator.language || 'en').toLowerCase();
    setLang(browser.startsWith('pl') ? 'pl' : 'en');
  }
</script>

<style>
  .lang-switcher {
    display: flex;
    border: 1px solid var(--border);
    overflow: hidden;
    border-radius: 2px;
  }

  .lang-btn {
    font-family: var(--mono);
    font-size: 0.68rem;
    padding: 0.28rem 0.6rem;
    background: none;
    border: none;
    color: var(--subtle);
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: background 0.15s, color 0.15s;
  }

  .lang-btn.active {
    background: var(--accent);
    color: #080a0c;
    font-weight: 500;
  }

  .lang-btn:not(.active):hover {
    background: var(--surface);
    color: var(--body);
  }
</style>
